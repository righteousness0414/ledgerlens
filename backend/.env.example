# ---- Database ----
# Default is a local SQLite file so the app runs with zero infrastructure.
# For Postgres (see docker-compose.yml), use e.g.:
#   DATABASE_URL=postgresql+psycopg2://ledgerlens:ledgerlens@localhost:5432/ledgerlens
DATABASE_URL=sqlite:///./ledgerlens.db

# ---- Object storage ----
STORAGE_DIR=./storage

# ---- Extraction provider ----
# One of: mock | claude | openai | google_vision
#   mock          – deterministic fake extractor, no API key needed (great for demos/tests)
#   claude        – Anthropic Claude vision  (needs ANTHROPIC_API_KEY)
#   openai        – OpenAI GPT vision        (needs OPENAI_API_KEY)
#   google_vision – Google Cloud Vision OCR + deterministic field parsing
#                   (needs GOOGLE_APPLICATION_CREDENTIALS). This mirrors the
#                   production family-business pipeline this PoC is based on.
EXTRACTION_PROVIDER=mock

# Claude
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Google Cloud Vision (path to a service-account JSON key)
GOOGLE_APPLICATION_CREDENTIALS=

# ---- Confidence ----
# Fields whose final confidence is below this threshold are flagged for review.
CONFIDENCE_THRESHOLD=0.85
# Multiplier applied to a field's model confidence when a validation check fails.
VALIDATION_PENALTY=0.5
# Hard cap on final confidence when a validation check fails.
VALIDATION_FAIL_CAP=0.4

# Expected invoice-number pattern (configurable per client).
INVOICE_NUMBER_REGEX=^[A-Za-z0-9][A-Za-z0-9\-/]{2,}$

# ---- CORS ----
FRONTEND_ORIGIN=http://localhost:3000
